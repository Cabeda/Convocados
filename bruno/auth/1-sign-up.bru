meta {
  name: 1. Sign Up (Email)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/sign-up/email
  body: json
  auth: none
}

body:json {
  {
    "name": "{{userName}}",
    "email": "{{email}}",
    "password": "{{password}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("userId", res.body.user?.id);
  }
}
