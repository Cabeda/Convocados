{
  "name": "convocados",
  "version": "3.115.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env node_modules/astro/bin/astro.mjs dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "sh ./scripts/start.sh",
    "setup-hooks": "sh ./scripts/install-hooks.sh",
    "lint": "eslint src/",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:mutation": "npx stryker run",
    "test:route-coverage": "bash scripts/route-coverage.sh",
    "test:e2e": "npx playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "sh -c 'set -a; . ./.env; set +a; npx tsx prisma/seed.ts'",
    "db:seed:settle": "sh -c 'set -a; . ./.env; set +a; npx tsx prisma/seed-settle-demo.ts'",
    "db:pull-prod": "sh ./scripts/pull-prod-db.sh",
    "dev:prod-db": "npm run db:pull-prod && DATABASE_URL=file:./prod-debug.db node --env-file=.env node_modules/.bin/astro dev --host 0.0.0.0",
    "lhci": "lhci autorun --config=lighthouserc.cjs",
    "k6:smoke": "k6 run k6/scripts/smoke.js",
    "k6:load": "k6 run k6/scripts/load.js",
    "k6:stress": "k6 run k6/scripts/stress.js",
    "k6:spike": "k6 run k6/scripts/spike.js",
    "k6:sse": "k6 run k6/scripts/sse.js",
    "sync:i18n": "tsx scripts/generate-android-strings.ts",
    "sync:feature-parity-docs": "tsx scripts/generate-feature-parity-docs.ts"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "@astrojs/react": "^6.0.1",
    "@better-auth/oauth-provider": "^1.6.23",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@prisma/client": "^6.19.3",
    "@types/web-push": "^3.6.4",
    "astro": "^7.0.7",
    "better-auth": "^1.6.23",
    "leaflet": "^1.9.4",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "prisma": "^6.19.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.9.2",
    "resend": "^6.17.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.13.1",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  },
  "packageManager": "pnpm@11.6.0"
}
