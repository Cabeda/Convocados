generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── better-auth tables ────────────────────────────────────────────────────────

model User {
  id             String          @id
  name           String
  email          String          @unique
  emailVerified  Boolean         @default(false)
  image          String?
  role           String          @default("user") // "user" | "admin"
  publicStats    Boolean         @default(true)
  profileVisibility String       @default("public") // "public" | "participants" | "private"
  // #457 push prompt state machine
  pushPromptState          String    @default("default") // "default" | "granted" | "dismissed" | "denied"
  pushPromptLastDismissedAt DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sessions       Session[]
  accounts       Account[]
  ownedEvents    Event[]         @relation("EventOwner")
  players        Player[]        @relation("PlayerUser")
  eventPlayers   EventPlayer[]   @relation("EventPlayerUser")
  calendarTokens CalendarToken[]
  apiKeys        ApiKey[]
  notificationPreferences NotificationPreferences?
  priorityEnrollments     PriorityEnrollment[]
  rsvps                   Rsvp[]
  rsvpsActedOn            Rsvp[]            @relation("RsvpActedBy")
  priorityConfirmations   PriorityConfirmation[]
  eventInvites            EventInvite[]
  adminEvents             EventAdmin[]  @relation("EventAdmins")
  followedEvents          EventFollow[] @relation("EventFollows")
  notifications           InAppNotification[] @relation("UserNotifications")
  pushSubscriptions       PushSubscription[]
  appPushTokens           AppPushToken[]
  oauthClients            OauthClient[]      @relation("OAuthClients")
  oauthTokens             OauthAccessToken[] @relation("OAuthTokens")
  oauthRefreshTokens      OauthRefreshToken[] @relation("OAuthRefreshTokens")
  oauthConsents           OauthConsent[]      @relation("OAuthConsents")
  courtWatches            CourtWatch[]        @relation("UserCourtWatches")
  monthlySubscriptions    MonthlySubscription[]
  appOpens                UserAppOpen[]
  walletTransactions      WalletTransaction[]
  paidWalletTransactions      WalletTransaction[] @relation("WalletTransactionPayer")
  receivedWalletTransactions  WalletTransaction[] @relation("WalletTransactionPaidTo")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  oauthAccessTokens  OauthAccessToken[]
  oauthRefreshTokens OauthRefreshToken[]
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── App tables ────────────────────────────────────────────────────────────────

model Event {
  id             String                @id @default(cuid())
  title          String
  location       String
  latitude       Float?
  longitude      Float?
  dateTime       DateTime
  timezone       String                @default("UTC")
  maxPlayers     Int                   @default(10)
  teamOneName    String                @default("Ninjas")
  teamTwoName    String                @default("Gunas")
  sport          String                @default("football-5v5")
  durationMinutes Int                  @default(60)
  isPublic       Boolean               @default(false)
  balanced       Boolean               @default(false)
  isRecurring    Boolean               @default(false)
  recurrenceRule String?
  nextResetAt    DateTime?
  ownerId        String?
  owner          User?                 @relation("EventOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  players        Player[]
  teamResults    TeamResult[]
  history        GameHistory[]
  playerRatings  PlayerRating[]
  webhookSubs    WebhookSubscription[]
  reminderLogs   ReminderLog[]
  eventCost      EventCost?
  eventLogs      EventLog[]
  priorityEnrollments PriorityEnrollment[]
  priorityConfirmations PriorityConfirmation[]
  rsvps                Rsvp[]
  invites         EventInvite[]
  admins          EventAdmin[]
  followers        EventFollow[]
  notificationJobs NotificationJob[]
  inAppNotifications InAppNotification[] @relation("EventNotifications")
  monthlySubscriptions  MonthlySubscription[]
  walletTransactions    WalletTransaction[]
  extrasDeclarations    ExtrasDeclaration[]

  // Occurrence-based recurrence (ADR 0016)
  currentGameId   String?
  games           Game[]
  eventPlayers    EventPlayer[]

  // Priority enrollment settings
  priorityEnabled       Boolean @default(false)
  priorityThreshold     Int     @default(3)   // min games attended in window
  priorityWindow        Int     @default(4)   // last N games to evaluate
  priorityMaxPercent    Int     @default(70)  // max % of maxPlayers reserved
  priorityDeadlineHours Int     @default(48)  // hours before game to close confirmations
  priorityMinGames      Int     @default(3)   // min total games before eligible

  // #457 RSVP — 48h-before ping idempotency
  rsvpCutoffSent Boolean @default(false)

  // ADR 0017: Dedup flag for few_spots_left notification (reset when player leaves)
  fewSpotsLeftNotified Boolean @default(false)

  // Recruitment notification dedup — T-48h and T-24h pings should fire only once per occurrence
  recruitment48hSent Boolean @default(false)
  recruitment24hSent Boolean @default(false)

  // Access control
  accessPassword        String?               // bcrypt-hashed password (null = no password)

  // Rating settings
  showCompetitiveData Boolean @default(true)  // top-level gate: hide rankings/scores/stats from players
  eloEnabled        Boolean @default(true)
  hideEloInTeams    Boolean @default(false)
  allowManualRating Boolean @default(false)

  // Cost tracking
  splitCostsEnabled Boolean @default(true)

  // Payment enforcement
  paymentEnforcementLevel String  @default("nudge") // "off" | "nudge" | "soft_gate" | "hard_gate"
  paymentGateThreshold    Float   @default(0)       // amount in event currency; 0 = any debt triggers
  showDebtorNames         Boolean @default(false)   // false = aggregate only; true = names visible to group

  // MVP voting
  mvpEnabled Boolean @default(true)
  mvpEloEnabled Boolean @default(false)

  // Notification defaults (admin-set, JSON: {mutePlayerActivity?, muteReminders?, mutePostGame?, muteEventDetails?})
  notificationDefaults String? // null = all enabled

  // Recruitment threshold — how many spots remaining triggers recruitment/few-spots-left notifications (ADR 0017)
  recruitmentThreshold Int @default(3)

  // ADR 0018: Auto-confirm attendance for recurring events
  autoConfirmEnabled   Boolean @default(false)
  autoConfirmThreshold Int     @default(3) // consecutive games attended to earn auto-confirm

  // Court Watch (JSON: {radius: number, indoor: boolean|null, surface: string|null}; null = disabled)
  courtWatchConfig String?
  courtWatchAlerts CourtWatchAlert[]

  // Archive
  archivedAt     DateTime?

  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([ownerId])
}

model GameHistory {
  id               String   @id @default(cuid())
  eventId          String
  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dateTime         DateTime
  status           String   @default("played") // "played" | "cancelled"
  scoreOne         Int?
  scoreTwo         Int?
  teamOneName      String
  teamTwoName      String
  teamsSnapshot    String? // JSON: [{team, players:[{name,order}]}]
  paymentsSnapshot String? // JSON: [{playerName, amount, status, method}]
  // Per-game payment method override. When set, this game's players see
  // these methods instead of the event default (or the event's
  // tempPaymentMethods). Same JSON shape as EventCost.paymentMethods:
  // [{type, value, label?, payerUserId?, payerName?}].
  paymentMethods   String?
  editableUntil    DateTime
  eloProcessed     Boolean  @default(false)
  isFriendly       Boolean  @default(false)
  source           String   @default("live") // "live" | "historical"
  createdAt        DateTime @default(now())
  mvpVotes         MvpVote[]
  walletTransactions WalletTransaction[]
}

model MvpVote {
  id               String      @id @default(cuid())
  gameHistoryId    String
  gameHistory      GameHistory  @relation(fields: [gameHistoryId], references: [id], onDelete: Cascade)
  voterPlayerId    String      // Player.id at time of vote
  voterName        String      // denormalized — resilient if Player record is later removed
  votedForPlayerId String      // Player.id at time of vote
  votedForName     String      // denormalized for the same reason
  createdAt        DateTime    @default(now())

  @@unique([gameHistoryId, voterPlayerId])
  @@index([gameHistoryId])
  @@index([votedForPlayerId])
}

model Player {
  id              String    @id @default(cuid())
  name            String
  order           Int       @default(0)
  eventId         String
  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?     @relation("PlayerUser", fields: [userId], references: [id], onDelete: SetNull)
  invitedByUserId String?
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  rsvps           Rsvp[]

  @@unique([eventId, name])
  @@index([userId])
}

model PlayerRating {
  id            String   @id @default(cuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name          String
  userId        String?
  rating        Float    @default(1000)
  initialRating Float?
  gamesPlayed   Int      @default(0)
  wins          Int      @default(0)
  draws         Int      @default(0)
  losses        Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([eventId, name])
  @@index([userId])
}

// ── ADR 0016: Occurrence-based recurrence ─────────────────────────────────────

model Game {
  id              String    @id @default(cuid())
  eventId         String
  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dateTime        DateTime
  status          String    @default("upcoming") // "upcoming" | "in_progress" | "played" | "cancelled"
  isFriendly      Boolean   @default(false)
  scoreOne        Int?
  scoreTwo        Int?
  teamOneName     String?
  teamTwoName     String?
  eloProcessed    Boolean   @default(false)
  rsvpCutoffSent  Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  participants    GameParticipant[]
  payments        GamePayment[]

  @@index([eventId, dateTime])
  @@index([eventId, status])
}

model EventPlayer {
  id            String   @id @default(cuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name          String
  userId        String?
  user          User?    @relation("EventPlayerUser", fields: [userId], references: [id], onDelete: SetNull)
  rating        Float    @default(1000)
  gamesPlayed   Int      @default(0)
  wins          Int      @default(0)
  draws         Int      @default(0)
  losses        Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  participations GameParticipant[]
  payments       GamePayment[]

  @@unique([eventId, name])
  @@index([userId])
}

model GameParticipant {
  id            String      @id @default(cuid())
  gameId        String
  game          Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  eventPlayerId String
  eventPlayer   EventPlayer @relation(fields: [eventPlayerId], references: [id], onDelete: Cascade)
  order         Int         @default(0)
  archivedAt    DateTime?
  noShow        Boolean     @default(false) // ADR 0018: marked by organizer post-game
  createdAt     DateTime    @default(now())

  @@unique([gameId, eventPlayerId])
  @@index([eventPlayerId])
}

model GamePayment {
  id            String      @id @default(cuid())
  gameId        String
  game          Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  eventPlayerId String
  eventPlayer   EventPlayer @relation(fields: [eventPlayerId], references: [id], onDelete: Cascade)
  playerName    String
  amount        Float
  status        String      @default("pending") // "pending" | "sent" | "paid"
  method        String?
  paidAt        DateTime?
  markedBy      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([gameId, eventPlayerId])
}

model TeamResult {
  id      String       @id @default(cuid())
  name    String
  eventId String
  event   Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  members TeamMember[]
}

model TeamMember {
  id           String     @id @default(cuid())
  name         String
  order        Int
  teamResultId String
  team         TeamResult @relation(fields: [teamResultId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String
  auth      String
  locale    String   @default("en")
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
}

model WebhookSubscription {
  id         String            @id @default(cuid())
  eventId    String
  event      Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url        String
  secret     String?
  events     String            @default("[]") // JSON array of event types
  disabled   Boolean           @default(false)
  createdAt  DateTime          @default(now())
  deliveries WebhookDelivery[]

  @@unique([eventId, url])
}

model WebhookDelivery {
  id          String              @id @default(cuid())
  webhookId   String
  webhook     WebhookSubscription @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventType   String
  payload     String // JSON
  status      String              @default("pending") // "pending" | "success" | "failed"
  attempts    Int                 @default(0)
  lastAttempt DateTime?
  deliveredAt DateTime?
  error       String?
  createdAt   DateTime            @default(now())
}

model ReminderLog {
  id      String   @id @default(cuid())
  eventId String
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type    String // "24h" | "2h" | "1h" | "post-game"
  sentAt  DateTime @default(now())

  @@unique([eventId, type])
}

model ScheduledJob {
  id          String    @id @default(cuid())
  eventId     String?
  type        String    // "reminder_24h" | "reminder_2h" | "reminder_1h" | "post_game" | ...
  payload     String    @default("{}") // JSON
  runAt       DateTime
  processedAt DateTime?
  failedAt    DateTime?
  retryCount  Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([runAt, processedAt])
  @@index([eventId])
}

model CalendarToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope     String   @default("user") // "user" | "event"
  scopeId   String? // eventId when scope is "event"
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  prefix     String // first 8 chars of the raw key for identification
  hashedKey  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes     String    @default("[]") // JSON array of scope strings
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([hashedKey])
}

model EventCost {
  id             String          @id @default(cuid())
  eventId        String          @unique
  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  totalAmount    Float
  currency       String          @default("EUR")
  paymentDetails String? // deprecated: free text, kept for backward compat
  paymentMethods String? // JSON: [{ type: "mbway"|"revolut_tag"|"revolut_link"|"phone", value: "...", label?: "..." }]
  tempPaymentMethods String? // JSON override, same format as paymentMethods — auto-cleared on recurrence reset
  tempPaymentDetails String? // free-text override, same format as paymentDetails — auto-cleared on recurrence reset
  payments       PlayerPayment[]
  // Monthly subscription (ADR 0008)
  monthlyEnabled        Boolean @default(false)
  monthlyFeeCents       Int?    // event currency, integer cents
  monthlyGamesCovered   Int     @default(5)
  // Drop-in surcharge (CONTEXT: Drop-in Surcharge)
  dropInSurchargeCents  Int     @default(0)
  // Extras pot (ADR 0009) — single running integer, never real money
  organizerExtrasCents  Int     @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PlayerPayment {
  id          String    @id @default(cuid())
  eventCostId String
  eventCost   EventCost @relation(fields: [eventCostId], references: [id], onDelete: Cascade)
  playerName  String
  amount      Float
  status      String    @default("pending") // "pending" | "paid"
  method      String? // free text: cash, revolut, mbway, transfer, etc.
  paidAt      DateTime?
  markedBy    String? // userId who marked it
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([eventCostId, playerName])
}

// ── Wallet / monthly subscription (ADR 0007, 0008, 0009) ────────────────────

model MonthlySubscription {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode         String   @default("monthly") // "monthly" (extensible to "season_pass" etc.)
  // Subscription Window — [windowStart, windowEnd) in the Event's timezone
  windowStart  DateTime
  windowEnd    DateTime
  // Snapshots of the EventCost config at the time the subscription was created
  feeCents     Int
  gamesCovered Int
  status       String   @default("active") // "active" | "cancelled"
  markedById   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([eventId, userId, windowStart])
  @@index([eventId, windowStart])
  @@index([userId])
}

model WalletTransaction {
  id              String   @id @default(cuid())
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Money
  amountCents     Int      // positive integer in Event currency
  currency        String   // snapshot of EventCost.currency at write time
  direction       String   // "debit" | "credit"
  // Game Units (only for missed_game_credit, credit_redeemed, credit_expired)
  gameUnits       Int      @default(0)
  // Categorisation
  reason          String   // "per_game_share" | "monthly_fee" | "missed_game_credit"
                           // | "credit_redeemed" | "credit_expired" | "extras_declare"
                           // | "payment_received" | "payment_self_reported"
  statusAfter     String?  // for payment_* rows: "sent" | "paid"
  // References
  eventInstanceId String?  // Event.id of the instance this row is about
  subscriptionId  String?  // MonthlySubscription.id
  extrasId        String?  // ExtrasDeclaration.id
  gameHistoryId   String?  // GameHistory.id — null for per-game-share debits/credits that are NOT bound to a historical game
  gameHistory     GameHistory? @relation(fields: [gameHistoryId], references: [id], onDelete: SetNull)
  // Player name snapshot (for ghost players whose User is a synthetic "ghost:{id}" account
  // — see scripts/wallet-backfill.ts). For linked users, this is a denormalized copy of
  // EventPlayer.name at the time of write; rename-tolerant because the read path joins on
  // userId, not on name.
  playerName      String?
  // Who actually handed over the money for this credit (the debtor's `userId` field above
  // is the person whose debt was cleared, which may or may not be the same person). Null
  // for non-payment-received rows or for legacy entries predating ADR 0019.
  payerUserId     String?
  payer           User?    @relation("WalletTransactionPayer", fields: [payerUserId], references: [id], onDelete: SetNull)
  // Who received the money (typically the event owner, but can be another player
  // collecting on the organizer's behalf).
  paidToUserId    String?
  paidTo          User?    @relation("WalletTransactionPaidTo", fields: [paidToUserId], references: [id], onDelete: SetNull)
  // Idempotency / authorship
  idempotencyKey  String?  // unique key for system-generated rows (expiry, etc.)
  markedById      String?  // who recorded this
  note            String?
  createdAt       DateTime @default(now())

  @@unique([idempotencyKey])
  @@index([eventId, userId, createdAt])
  @@index([eventId, createdAt])
  @@index([eventInstanceId])
  @@index([gameHistoryId])
  @@index([eventId, userId, gameHistoryId])
  @@index([playerName])
  @@index([payerUserId])
  @@index([paidToUserId])
}

model ExtrasDeclaration {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  amountCents Int
  currency    String
  label       String
  declaredBy  String   // userId of the organizer
  declaredAt  DateTime @default(now())

  @@index([eventId, declaredAt])
}

// ── Notification preferences ──────────────────────────────────────────────────

model NotificationPreferences {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Global toggles — email off by default, push on (web + future app)
  emailEnabled         Boolean  @default(false)
  pushEnabled          Boolean  @default(true)

  // Per-type toggles
  gameInviteEmail      Boolean  @default(false)
  gameInvitePush       Boolean  @default(true)
  gameReminderEmail    Boolean  @default(false)
  gameReminderPush     Boolean  @default(true)
  playerActivityPush   Boolean  @default(true)   // player joined/left
  eventDetailsPush     Boolean  @default(true)   // date/location/title changes
  postGamePush         Boolean  @default(true)   // post-game results
  weeklySummaryEmail   Boolean  @default(false)
  paymentReminderEmail Boolean  @default(false)
  paymentReminderPush  Boolean  @default(true)

  // Reminder time preferences
  reminder24h          Boolean  @default(true)
  reminder2h           Boolean  @default(true)
  reminder1h           Boolean  @default(false)

  // ADR 0018: Organizer daily digest mode
  digestMode           Boolean  @default(false)
  digestTime           String   @default("09:00") // HH:MM in user's timezone

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ── Mobile app push tokens (React Native / Expo) ──────────────────────────────

model AppPushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique  // Expo push token or FCM/APNs token
  platform  String            // "ios" | "android"
  locale    String   @default("en") // User's preferred locale for push messages
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ── Event activity log ────────────────────────────────────────────────────────

model EventLog {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  action    String   // e.g. "player_added", "player_removed", "cost_set", "teams_randomized"
  actor     String?  // user name or null for anonymous
  actorId   String?  // userId if authenticated
  details   String   @default("{}") // JSON with action-specific data
  createdAt DateTime @default(now())

  @@index([eventId, createdAt])
}

// ── Priority enrollment ───────────────────────────────────────────────────────

model PriorityEnrollment {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source    String   @default("auto")  // "auto" (earned) | "manual" (owner added)
  optedIn   Boolean  @default(true)    // player can opt out
  declineStreak Int  @default(0)       // consecutive declines — pauses at 3
  noShowStreak  Int  @default(0)       // consecutive no-shows — loses priority at 2
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
}

model PriorityConfirmation {
  id          String    @id @default(cuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameDate    DateTime
  status      String    @default("pending")  // "pending" | "confirmed" | "declined" | "expired"
  notifiedAt  DateTime
  respondedAt DateTime?
  deadline    DateTime
  createdAt   DateTime  @default(now())

  @@unique([eventId, userId, gameDate])
  @@index([eventId, gameDate])
  @@index([deadline])
}

// ── Event access control ──────────────────────────────────────────────────────

model EventInvite {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

// ── Event admins (shared management) ──────────────────────────────────

model EventAdmin {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("EventAdmins", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([userId])
}

// ── Event follows (dashboard visibility) ─────────────────────────────────

model EventFollow {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("EventFollows", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  // Per-event notification overrides (null = use global default)
  mutePlayerActivity Boolean?
  muteReminders      Boolean?
  mutePostGame       Boolean?
  muteEventDetails   Boolean?

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
}

// ── Payment reminder log ──────────────────────────────────────────────────────

model PaymentReminderLog {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  sentAt    DateTime @default(now())

  @@unique([eventId, userId, sentAt])
  @@index([eventId, userId])
}

// ADR 0018: Payment nudge escalation stage tracker (per player-event)
model PaymentNudgeStage {
  id            String   @id @default(cuid())
  eventId       String
  userId        String
  stage         Int      @default(0) // 0=not started, 1=soft nudge, 2=follow-up, 3=social proof
  lastSentAt    DateTime?
  organiserAlert Boolean @default(false) // true after stage 3 fires + organizer is notified
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([eventId, userId])
  @@index([eventId])
}

// ── Notification job queue ────────────────────────────────────────────────────

model NotificationJob {
  id             String    @id @default(cuid())
  eventId        String
  event          Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type           String    // "player_joined" | "player_left" | "player_joined_bench" | "player_left_bench" | "player_left_promoted" | "event_details" | "reminder"
  // NOTE(postgres): When adding Postgres support (#236), consider migrating this
  // column to native Json type for better querying. The drain code does
  // JSON.parse(job.payload) — if changed to Json, remove that parse call.
  payload        String    @default("{}") // JSON string
  senderClientId String?   // suppress sending back to originator
  retryCount     Int       @default(0)
  failedAt       DateTime? // set when all retries exhausted (dead-letter)
  createdAt      DateTime  @default(now())
  processedAt    DateTime?

  // NOTE(postgres): Replace the $transaction claim approach with
  // SELECT ... FOR UPDATE SKIP LOCKED when on Postgres (#236) to get
  // true atomic claiming under READ COMMITTED isolation.
  @@index([processedAt, createdAt])
  @@index([failedAt])
  @@index([eventId])
}

model InAppNotification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  eventId   String?
  event     Event?    @relation("EventNotifications", fields: [eventId], references: [id], onDelete: Cascade)
  type      String    // matches NotificationJobType
  title     String
  body      String
  url       String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([eventId])
}

// ── OAuth 2.1 (@better-auth/oauth-provider) ──────────────────────────────────

/// JWT signing keys for the OAuth provider
model Jwks {
  id         String    @id
  publicKey  String
  privateKey String
  createdAt  DateTime
  expiresAt  DateTime?

  @@map("jwks")
}

/// New OAuth client table used by @better-auth/oauth-provider
model OauthClient {
  id                      String   @id
  clientId                String   @unique
  clientSecret            String?
  disabled                Boolean? @default(false)
  skipConsent             Boolean?
  enableEndSession        Boolean?
  subjectType             String?
  scopes                  String?
  userId                  String?
  user                    User?    @relation("OAuthClients", fields: [userId], references: [id], onDelete: Cascade)
  createdAt               DateTime?
  updatedAt               DateTime?
  name                    String?
  uri                     String?
  icon                    String?
  contacts                String?
  tos                     String?
  policy                  String?
  softwareId              String?
  softwareVersion         String?
  softwareStatement       String?
  redirectUris            String
  postLogoutRedirectUris  String?
  tokenEndpointAuthMethod String?
  grantTypes              String?
  responseTypes           String?
  public                  Boolean?
  type                    String?
  requirePKCE             Boolean?
  referenceId             String?
  metadata                String?

  refreshTokens OauthRefreshToken[]
  accessTokens  OauthAccessToken[]
  consents      OauthConsent[]

  @@index([userId])
  @@map("oauthClient")
}

/// Refresh tokens (split from old OauthAccessToken)
model OauthRefreshToken {
  id          String    @id
  token       String    @unique
  clientId    String
  client      OauthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  sessionId   String?
  session     Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  userId      String
  user        User      @relation("OAuthRefreshTokens", fields: [userId], references: [id], onDelete: Cascade)
  referenceId String?
  expiresAt   DateTime?
  createdAt   DateTime?
  revoked     DateTime?
  authTime    DateTime?
  scopes      String

  accessTokens OauthAccessToken[]

  @@index([clientId])
  @@index([sessionId])
  @@index([userId])
  @@map("oauthRefreshToken")
}

/// Access tokens for the new oauth-provider plugin
model OauthAccessToken {
  id          String    @id
  token       String    @unique
  clientId    String
  client      OauthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  sessionId   String?
  session     Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?     @relation("OAuthTokens", fields: [userId], references: [id], onDelete: Cascade)
  referenceId String?
  refreshId   String?
  refresh     OauthRefreshToken? @relation(fields: [refreshId], references: [id], onDelete: Cascade)
  expiresAt   DateTime?
  createdAt   DateTime?
  scopes      String?

  @@index([clientId])
  @@index([userId])
  @@index([sessionId])
  @@index([refreshId])
  @@map("oauthAccessToken")
}

/// OAuth consent records
model OauthConsent {
  id           String    @id @default(cuid())
  clientId     String
  client       OauthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  userId       String
  user         User      @relation("OAuthConsents", fields: [userId], references: [id], onDelete: Cascade)
  scopes       String
  consentGiven Boolean
  referenceId  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([clientId])
  @@index([userId])
  @@map("oauthConsent")
}

// ── Court Watch alerts (deduplication) ────────────────────────────────────────

model CourtWatchAlert {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tenantId    String   // Playtomic club ID
  tenantName  String
  resourceId  String   // Playtomic court ID
  resourceName String
  slotTime    String   // "HH:mm" of the available slot
  slotDate    String   // "YYYY-MM-DD"
  duration    Int      // minutes
  price       Float?
  currency    String?  @default("EUR")
  coordinate  String?  // JSON: {lat, lon}
  address     String?  // club address string
  notifiedAt  DateTime @default(now())

  @@unique([eventId, tenantId, resourceId, slotDate, slotTime])
  @@index([eventId])
}

// Standalone recurring court watch: notify a user when a specific Playtomic
// court becomes available in a recurring weekday/time window. Independent of events.
model CourtWatch {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("UserCourtWatches", fields: [userId], references: [id], onDelete: Cascade)
  sport        String   // Convocados sport id (e.g. "padel")
  tenantId     String   // Playtomic club id
  tenantName   String
  resourceId   String?  // specific court; null = any court at the club
  resourceName String?
  dayOfWeek    Int      // 0=Sunday .. 6=Saturday (matched in club-local time)
  startTime    String   // "HH:mm" window start (club-local)
  endTime      String   // "HH:mm" window end (club-local)
  durationMinutes Int   @default(90)
  timezone     String   @default("UTC") // label for display; matching is club-local
  maxPrice     Float?   // optional: only notify when price <= this
  active       Boolean  @default(true)
  lastCheckedAt DateTime? // for chunked cron processing (oldest-first)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  hits         CourtWatchHit[]

  @@index([userId])
  @@index([active])
}

// Dedup record: a specific available slot already notified for a watch.
model CourtWatchHit {
  id           String     @id @default(cuid())
  watchId      String
  watch        CourtWatch @relation(fields: [watchId], references: [id], onDelete: Cascade)
  resourceId   String
  slotDate     String     // "YYYY-MM-DD"
  slotTime     String     // "HH:mm"
  notifiedAt   DateTime   @default(now())

  @@unique([watchId, resourceId, slotDate, slotTime])
  @@index([watchId])
}

// Short-TTL cache of Playtomic availability, keyed by club+sport+date.
// Lets many watches (and the live search) share a single upstream fetch and
// avoids hammering Playtomic / getting the IP blocked.
model PlaytomicAvailabilityCache {
  cacheKey   String   @id // "{tenantId}|{sport}|{date}"
  courtsJson String   // JSON array of PlaytomicCourtAvailability (all durations)
  fetchedAt  DateTime @default(now())

  @@index([fetchedAt])
}

// #457 RSVP per (subject, Event). status null == pending.
// A row is keyed by exactly one of {userId, playerId}: userId for linked accounts
// (the user self-RSVPs), playerId for guest Players (the admin RSVPs on their
// behalf). respondedByUserId audits who set a guest RSVP — null for self-RSVPs.
// Application invariant: (userId IS NULL) XOR (playerId IS NULL) must be false
// i.e. exactly one is set. SQLite unique constraints on nullable columns treat
// NULL as distinct, so this is enforced in lib/rsvp.server.ts, not in the schema.
model Rsvp {
  id                String    @id @default(cuid())
  userId            String?
  playerId          String?
  eventId           String
  status            String?   // "yes" | "no" | null
  respondedAt       DateTime?
  respondedByUserId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  player            Player?   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  respondedBy       User?     @relation("RsvpActedBy", fields: [respondedByUserId], references: [id], onDelete: SetNull)
  event             Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@unique([playerId, eventId])
  @@index([eventId, status])
}

// #457 daily heartbeat for "≥3 app-open days in rolling 7d" re-prompt rule.
model UserAppOpen {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day    DateTime // truncated to date (UTC)

  @@unique([userId, day])
  @@index([userId, day])
}
