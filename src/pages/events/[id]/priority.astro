---
import PrioritySettingsPage from "../../../components/PrioritySettingsPage";

const { id } = Astro.params;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Priority Enrollment</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#1b6b4a" />
  </head>
  <body>
    <PrioritySettingsPage client:only="react" eventId={id!} isOwner={false} isAuthenticated={false} eventTitle="" />
  </body>
</html>
